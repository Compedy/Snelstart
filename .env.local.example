# Subscription key van https://b2bapi-developer.snelstart.nl (profiel > subscriptions)
# Gedeeld door alle projecten
SNELSTART_SUBSCRIPTION_KEY=

# Project 1 — bijv. Kaasboer BV
PROJECT_1_NAAM=Kaasboer BV
PROJECT_1_API_KEY=genereer-een-willekeurige-string    # Dit stuur je mee vanuit de frontend
PROJECT_1_CLIENT_KEY=                                 # Snelstart client key van deze klant

# Project 2 — bijv. Autobedrijf Jansen
PROJECT_2_NAAM=Autobedrijf Jansen
PROJECT_2_API_KEY=genereer-een-andere-willekeurige-string
PROJECT_2_CLIENT_KEY=

# Meer projecten? Voeg PROJECT_3_*, PROJECT_4_* etc. toe
